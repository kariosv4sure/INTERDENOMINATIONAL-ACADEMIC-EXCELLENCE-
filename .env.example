# Flask Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-2024

# Database - PostgreSQL (External URL)
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://username:password@localhost:5432/iae_db

# For production with external PostgreSQL (e.g., Neon, Railway, Supabase)
# DATABASE_URL=postgresql://user:pass@ep-cool-water-123456.us-east-2.aws.neon.tech/iae_db?sslmode=require

# Groq API Configuration
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

# Admin Credentials (for first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Optional: For production, use these instead
# ADMIN_USERNAME=iae_admin
# ADMIN_PASSWORD=ChangeMe123!
